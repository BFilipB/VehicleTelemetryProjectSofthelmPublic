{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CloudSync": {
    "Enabled": true,
    "SyncIntervalSeconds": 60,
    "RecordsPerDevicePerSync": 5,
    "MaxRetries": 3,
    "TimeoutSeconds": 30,
    "MaxParallelDevices": 10
  }
}
